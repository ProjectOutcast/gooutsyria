# --- Required ---

# PostgreSQL connection string.
# Railway: add a PostgreSQL service and reference ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gooutsyria"

# Auth.js session encryption secret. Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Public origin of the site (used in metadata, sitemap, JSON-LD)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Recommended in production ---

# Behind a proxy (Railway), Auth.js needs this
AUTH_TRUST_HOST="true"

# Where uploaded photos are written. On Railway, mount a Volume (e.g. at
# /data) and set this to /data/uploads — otherwise uploads vanish on deploy.
UPLOAD_DIR="./public/uploads"

# --- Optional: Google sign-in (works without it — email/password only) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
